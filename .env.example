# ── HomeFirst Vernacular Loan Counselor — API Keys ───────────────
# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# OpenAI (GPT-4o) — from platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Sarvam AI (Hindi/Indian STT) — from dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ElevenLabs (TTS) — from elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice IDs — from elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID_ENGLISH=your_english_voice_id
ELEVENLABS_VOICE_ID_HINDI=your_hindi_voice_id
ELEVENLABS_VOICE_ID_MARATHI=your_marathi_voice_id
ELEVENLABS_VOICE_ID_TAMIL=your_tamil_voice_id

# Supabase — from supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
